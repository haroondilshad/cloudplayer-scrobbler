{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./js",
    "baseUrl": "./",
    "paths": {
      "*": ["node_modules/*", "js/*"]
    }
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
